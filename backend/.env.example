# Copy to backend/.env and adjust values.

# development | production
FLASK_ENV=development

# Strong random strings in production
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too

# SQLite (default)
DATABASE_URL=sqlite:///team_task_manager.db

# PostgreSQL (Railway provides DATABASE_URL — use postgresql://...)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# MySQL (install PyMySQL: pip install PyMySQL)
# DATABASE_URL=mysql+pymysql://user:password@host:3306/dbname

# Comma-separated browser origins allowed to call the API
CORS_ORIGINS=http://localhost:5173

# Optional: JWT lifetime in hours
JWT_ACCESS_HOURS=24

# Server port (Flask dev / some hosts)
PORT=5000
